# 런타임 환경변수 계약 (lib/config/env.ts가 부팅 시 검증)
# 배포 시에는 이 값들을 AWS Secrets Manager에 넣고 deploy.sh가 app.env로 주입한다.

# DB — compose.yml이 postgres 서비스로 주입
DATABASE_URL=postgres://app:app@localhost:5432/app

# Auth.js v5
AUTH_SECRET=changeme-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# AWS / S3 (선택)
AWS_REGION=ap-northeast-2
S3_BUCKET=

# 초기 관리자 시드 (deploy.sh가 있으면 db:seed 실행)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=
